    },
    {
      "type": "header",
      "content": "t:sections.common.custom_attr.header"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "t:sections.common.custom_attr.custom_id"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "t:sections.common.custom_attr.custom_class"
    },
    {
      "type": "header",
      "content": "t:settings_schema.animations.header.content"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "t:settings_schema.animations.header__2.content",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "t:settings_schema.animations.settings.animation.options.option_6"
        },
        {
          "value": "fade-in",
          "label": "t:settings_schema.animations.settings.animation.options.option_2"
        },
        {
          "value": "fade-in-up",
          "label": "t:settings_schema.animations.settings.animation.options.option_3"
        },
        {
          "value": "fade-in-left",
          "label": "t:settings_schema.animations.settings.animation.options.option_4"
        },
        {
          "value": "fade-in-right",
          "label": "t:settings_schema.animations.settings.animation.options.option_5"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "t:sections.product-tabs.blocks.tab.name",
      "settings": [
        {
          "type": "text",
          "label": "t:sections.product-tabs.blocks.tab.settings.title.label",
          "id": "title",
          "info": "t:sections.product-tabs.blocks.tab.settings.title.info"
        },
        {
          "type": "collection",
          "label": "t:sections.product-tabs.blocks.tab.settings.collection.label",
          "id": "collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-tabs.presets.name",
      "settings": {
        "heading": "Product tabs"
      },
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "Tab 1"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Tab 2"
          }
        }
      ]
    }
  ]
}
{% endschema %}
