{% comment %}
  Section: GVM Comparison / Specification
  - Desktop: table-style grid with bottom borders only (no outer border)
  - Mobile: STACKED cards (no horizontal scrolling)
  - Updated to support up to 10 comparison columns
{% endcomment %}

{%- liquid
  assign max_cols = 10
  assign cols = section.settings.columns | plus: 0

  if cols < 2
    assign cols = 2
  endif

  if cols > max_cols
    assign cols = max_cols
  endif

  assign container_width = section.settings.container_width | default: '1200px'
  assign anchor_id = section.settings.anchor_id | strip
-%}

<section
  class="gvm-compare gvm-compare--{{ section.id }}"
  {% if anchor_id != blank %}id="{{ anchor_id | escape }}"{% endif %}
  style="
    --gvm-max-width: {{ container_width }};
    --gvm-text: {{ section.settings.text_color }};
    --gvm-line: {{ section.settings.line_color }};
    --gvm-heading: {{ section.settings.heading_color }};
    --gvm-card-bg: {{ section.settings.mobile_card_bg }};
    --gvm-card-text: {{ section.settings.mobile_card_text }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="gvm-compare__container">
    {% if section.settings.heading != blank %}
      <h2 class="gvm-compare__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gvm-compare__table" data-cols="{{ cols }}" style="--gvm-cols: {{ cols }};">
      <!-- Header Row (hidden on mobile via CSS) -->
      <div class="gvm-compare__row gvm-compare__row--head">
        <div class="gvm-compare__cell gvm-compare__cell--label gvm-compare__cell--head">
          {{ section.settings.details_heading }}
        </div>

        {%- for i in (1..10) -%}
          {%- if i <= cols -%}
            {%- assign key = 'col_title_' | append: i -%}
            <div class="gvm-compare__cell gvm-compare__cell--head">
              {{ section.settings[key] }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Body Rows -->
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'divider' -%}
            <div class="gvm-compare__divider" {{ block.shopify_attributes }}></div>

          {%- when 'row' -%}
            {%- liquid
              assign label = block.settings.label | strip
            -%}
            <div class="gvm-compare__row" {{ block.shopify_attributes }}>
              <!-- Row label becomes the "card header" on mobile -->
              <div class="gvm-compare__cell gvm-compare__cell--label gvm-compare__cell--rowhead">
                {% if label != blank %}
                  {{ label | newline_to_br }}
                {% endif %}
              </div>

              {%- for i in (1..10) -%}
                {%- if i <= cols -%}
                  {%- assign tkey = 'col_title_' | append: i -%}
                  {%- assign col_title = section.settings[tkey] | strip -%}
                  {%- if col_title == blank -%}
                    {%- assign col_title = 'Column ' | append: i -%}
                  {%- endif -%}

                  {%- assign vkey = 'value_' | append: i -%}
                  {%- assign raw = block.settings[vkey] | default: '' -%}
                  {%- assign val = raw | strip -%}

                  <div class="gvm-compare__cell gvm-compare__cell--val" data-label="{{ col_title | escape }}">
                    {% render 'gvm-compare-value', value: val %}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% style %}
  .gvm-compare { color: var(--gvm-text); }

  .gvm-compare__container {
    max-width: var(--gvm-max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  .gvm-compare__heading {
    margin: 0 0 24px;
    font-size: 34px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--gvm-heading);
  }

  .gvm-compare__table { width: 100%; }

  /* Default desktop grid */
  .gvm-compare__row {
    display: grid;
    grid-template-columns: 240px repeat(var(--gvm-cols), minmax(140px, 1fr));
    column-gap: 40px;
    padding: 18px 0;
    border-bottom: 1px solid var(--gvm-line);
  }

  /* Tighten desktop spacing as columns increase (prevents ugly overflow/squish) */
  .gvm-compare__table[data-cols="6"] .gvm-compare__row,
  .gvm-compare__table[data-cols="7"] .gvm-compare__row {
    grid-template-columns: 220px repeat(var(--gvm-cols), minmax(110px, 1fr));
    column-gap: 24px;
  }

  .gvm-compare__table[data-cols="8"] .gvm-compare__row,
  .gvm-compare__table[data-cols="9"] .gvm-compare__row,
  .gvm-compare__table[data-cols="10"] .gvm-compare__row {
    grid-template-columns: 200px repeat(var(--gvm-cols), minmax(95px, 1fr));
    column-gap: 18px;
  }

  .gvm-compare__row--head { padding-top: 0; padding-bottom: 14px; }

  .gvm-compare__cell { font-size: 16px; line-height: 1.5; }

  .gvm-compare__table[data-cols="8"] .gvm-compare__cell,
  .gvm-compare__table[data-cols="9"] .gvm-compare__cell,
  .gvm-compare__table[data-cols="10"] .gvm-compare__cell {
    font-size: 15px;
  }

  .gvm-compare__cell--head {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 13px;
  }

  .gvm-compare__table[data-cols="10"] .gvm-compare__cell--head {
    font-size: 12px;
  }

  .gvm-compare__cell--label { font-weight: 600; }

  .gvm-compare__divider {
    height: 26px;
    border-bottom: 1px solid var(--gvm-line);
  }

  .gvm-compare__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    line-height: 1;
    transform: translateY(1px);
  }
  .gvm-compare__icon--check { color: #6b7b2a; }
  .gvm-compare__icon--cross { color: currentColor; }

  /* =========================
     MOBILE: stacked cards
  ========================= */
  @media (max-width: 989px) {
    .gvm-compare__row--head { display: none !important; }

    .gvm-compare__row {
      display: block;
      padding: 0;
      margin: 0 0 14px;
      border: 1px solid rgba(0,0,0,0.15);
      border-radius: 12px;
      overflow: hidden;
      background: var(--gvm-card-bg);
      color: var(--gvm-card-text);
      box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    }

    .gvm-compare__divider { height: 10px; border: 0; }

    .gvm-compare__cell {
      padding: 10px 14px;
      font-size: 14px;
      border: 0;
      white-space: normal;
    }

    .gvm-compare__cell--rowhead {
      background: rgba(0,0,0,0.06);
      font-weight: 800;
      font-size: 15px;
      padding: 12px 14px;
    }

    .gvm-compare__cell--val {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      border-top: 1px solid rgba(0,0,0,0.12);
      text-align: right;
    }

    .gvm-compare__cell--val::before {
      content: attr(data-label);
      font-weight: 600;
      color: rgba(0,0,0,0.72);
      min-width: 110px;
      text-align: left;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "GVM Comparison",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID (optional)", "default": "compare" },

    { "type": "text", "id": "heading", "label": "Heading", "default": "GVM Upgrade Comparison" },
    { "type": "text", "id": "details_heading", "label": "Details column heading", "default": "DETAILS" },

    {
      "type": "select",
      "id": "columns",
      "label": "Number of comparison columns",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" },
        { "value": "7", "label": "7" },
        { "value": "8", "label": "8" },
        { "value": "9", "label": "9" },
        { "value": "10", "label": "10" }
      ]
    },

    { "type": "text", "id": "col_title_1", "label": "Column 1 title", "default": "FACTORY" },
    { "type": "text", "id": "col_title_2", "label": "Column 2 title", "default": "STAGE 1" },
    { "type": "text", "id": "col_title_3", "label": "Column 3 title", "default": "STAGE 2" },
    { "type": "text", "id": "col_title_4", "label": "Column 4 title", "default": "STAGE 3" },
    { "type": "text", "id": "col_title_5", "label": "Column 5 title", "default": "STAGE 4" },
    { "type": "text", "id": "col_title_6", "label": "Column 6 title", "default": "STAGE 5" },
    { "type": "text", "id": "col_title_7", "label": "Column 7 title", "default": "STAGE 6" },
    { "type": "text", "id": "col_title_8", "label": "Column 8 title", "default": "STAGE 7" },
    { "type": "text", "id": "col_title_9", "label": "Column 9 title", "default": "STAGE 8" },
    { "type": "text", "id": "col_title_10", "label": "Column 10 title", "default": "STAGE 9" },

    { "type": "text", "id": "container_width", "label": "Container width (e.g. 1200px or 100%)", "default": "1200px" },

    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Desktop text color", "default": "#111111" },
    { "type": "color", "id": "line_color", "label": "Desktop line color", "default": "#111111" },

    { "type": "color", "id": "mobile_card_bg", "label": "Mobile card background", "default": "#f5f3ee" },
    { "type": "color", "id": "mobile_card_text", "label": "Mobile card text", "default": "#111111" },

    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "textarea", "id": "label", "label": "Left label (DETAILS)", "default": "GVM" },

        { "type": "textarea", "id": "value_1", "label": "Value (Column 1)", "default": "3,300kg" },
        { "type": "textarea", "id": "value_2", "label": "Value (Column 2)", "default": "3,650kg" },
        { "type": "textarea", "id": "value_3", "label": "Value (Column 3)", "default": "3,650kg" },
        { "type": "textarea", "id": "value_4", "label": "Value (Column 4)", "default": "3,850kg" },
        { "type": "textarea", "id": "value_5", "label": "Value (Column 5)" },
        { "type": "textarea", "id": "value_6", "label": "Value (Column 6)" },
        { "type": "textarea", "id": "value_7", "label": "Value (Column 7)" },
        { "type": "textarea", "id": "value_8", "label": "Value (Column 8)" },
        { "type": "textarea", "id": "value_9", "label": "Value (Column 9)" },
        { "type": "textarea", "id": "value_10", "label": "Value (Column 10)" }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "GVM Comparison",
      "blocks": [
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
