{"sections":{"main":{"type":"main-page","disabled":true,"settings":{}},"slideshow_CtnG98":{"type":"slideshow","blocks":{"slide_bW6A4P":{"type":"slide","settings":{"background":"shopify:\/\/shop_images\/2000x560_-_TOYOTA_TUNDRA_8ccf3a3a-faf2-4f60-82eb-86b1896b7e42.png","image_overlay_opacity":0,"content_position":"center","text_alignment":"center","text_color":"#000000","title":"","heading_size":"h2","heading_color":"","subheading":"","description":"","desc_size":"text-desc-base","button_text_1":"","button_link_1":"","button_style_1":"btn--primary","button_size_1":"","button_text_2":"","button_link_2":"","button_style_2":"btn--primary","button_size_2":""}}},"block_order":["slide_bW6A4P"],"name":"t:sections.slideshow.name","settings":{"container":"container-full","slideshow_height":"adapt","show_dots":false,"show_nav":false,"autoplay":false,"autorotate_speed":3,"pagination_background":"light","controls_position":"center","pagination_style":"dots","show_text_below":false,"text_alignment_mobile":"center","accessibility_info":"Slideshow about our brand","custom_id":"","custom_class":"","enable_bg_zoom_effect":false}},"jump_links_UeawGp":{"type":"jump-links","blocks":{"link_C8imG8":{"type":"link","settings":{"label":"GVM Packages","target_id":"gvmpackages"}},"link_y9rErk":{"type":"link","settings":{"label":"GVM Specification","target_id":"gvmspecification"}},"link_8FKHCp":{"type":"link","settings":{"label":"Suspension Collection","target_id":"suspensioncollection"}},"link_KmD9dx":{"type":"link","settings":{"label":"GVM Experts","target_id":"gvmexperts"}}},"block_order":["link_C8imG8","link_y9rErk","link_8FKHCp","link_KmD9dx"],"name":"Jump links","settings":{"container_mode":"full","container_width":"1200","bg_color":"#ffffff","text_color":"#111111","hover_color":"#111111","active_color":"#111111","border_color":"#0000001f","pad_y":10,"offset":0,"duration":650}},"rich_text_GbXVUF":{"type":"rich-text","blocks":{"heading_XhCLHT":{"type":"heading","settings":{"heading":"<strong>Toyota Tundra Unbound: Australia’s Premier GVM & GCM Legal Evolution. <\/strong>","highlight_style":"none","enable_highlight_text_color":true,"heading_size":"h1","heading_color":"#5683c2"}},"text_CfcJd4":{"type":"text","settings":{"text":"<p>Stop worrying about weight limits and start adventuring with absolute confidence. <strong>Offroad Industries (ORI)<\/strong> offers Australia’s most comprehensive, <strong>Federally Approved GVM (Gross Vehicle Mass)<\/strong> upgrades for the Toyota Australia Toyota Tundra 2023 - 2026 range—covering both the <strong>Limited<\/strong> and <strong>Platinum<\/strong> models.<\/p><p>By bundling our ORI GVM Packages with <strong>GCM testing and LS16 certification<\/strong>, we grant your truck true \"Super-Truck\" status. The <strong>LS16 code<\/strong> is our secret sauce: a specific engineering modification code for <strong>Gross Combination Mass Re-rating<\/strong>. This ensures your truck, your gear, and your 4.5T trailer are 100% legal together, whether registered <strong>Pre-Rego (Federal)<\/strong> or <strong>Post-Rego (State-based)<\/strong>.<\/p><p><\/p><p>*<strong>Please note that some workshops may apply additional discretionary administration fees to the quoted installation and engineering price. Additionally, all Post-Registration GVM upgrades will incur additional local fees. Shipping is not included in the price.<\/strong><br\/><br\/><\/p>"}}},"block_order":["heading_XhCLHT","text_CfcJd4"],"name":"t:sections.rich-text.presets.name","settings":{"container":"container","color_schema":"","text_alignment":"left","padding_top":40,"padding_bottom":0,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"rich_text_PtmRiF":{"type":"rich-text","blocks":{"heading_mpxUJy":{"type":"heading","settings":{"heading":"ORI Federally Approved Packages","highlight_style":"underline","enable_highlight_text_color":true,"heading_size":"h1","heading_color":"#5683c2"}}},"block_order":["heading_mpxUJy"],"name":"t:sections.rich-text.presets.name","settings":{"container":"container","color_schema":"","text_alignment":"left","padding_top":40,"padding_bottom":0,"show_section_divider":false,"divider_width":"container","custom_id":"gvmpackages","custom_class":"","animations":"inherit"}},"image_with_text_WcaAiR":{"type":"image-with-text","blocks":{"subheading_JVKNjL":{"type":"subheading","settings":{"subheading":"Stage 1: $15,499* Installed & Engineered"}},"heading_f9G7kD":{"type":"heading","settings":{"heading":"<strong>Stage 1: The Weekender Family Getaway<\/strong>","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2"}},"text_fRRw7g":{"type":"text","settings":{"text":"<p><em>The perfect entry point for a legal payload boost without the need for aftermarket wheels.<\/em><\/p><ul><li><strong>GVM Rating:<\/strong> 3,850kg (Boosting payload to <strong>1,028kg<\/strong>) <strong>GCM Rating:<\/strong> 8,350kg (Retains full 4.5T towing)<\/li><li><strong>Key Features:<\/strong> Fox 2.5 Performance Elite suspension, ORI 150–300kg coil packs, and heavy-duty BDS Upper Control Arms & Diff Drop.<\/li><li><strong>Best For:<\/strong> Daily drivers and light touring. Ideal for owners needing to clear the <strong>\"one-tonne\" mark for FBT Tax Compliance<\/strong> while keeping their factory wheels.<\/li><li><strong>The Benefit:<\/strong> Achieve a lifted, aggressive stance with premium USA-made shocks. This setup significantly improves stability under load without the added expense of new wheels and tyres. The Fox adjustability allows you to \"dial in\" your ride—stiffen it for the highway and soften it for the tracks with the simple turn of a knob.<\/li><li><strong>Part Number: <\/strong>TUN-Stage1-GVM<\/li><\/ul>"}}},"block_order":["subheading_JVKNjL","heading_f9G7kD","text_fRRw7g"],"name":"t:sections.image-with-text.presets.name","settings":{"container":"container","color_schema":"","image":"shopify:\/\/shop_images\/GVM_TOYOTA-TUNDRA-20260504stage-1--3850GVM-_-8350-GCM.png","image_width":"50%","image_position":"left","vertical_alignment":"center","column_gap":"medium","row_gap":"medium","padding_left":0,"padding_right":0,"align_content_container":"none","mobile_padding_left":15,"mobile_padding_right":15,"padding_top":40,"padding_bottom":40,"padding_top_mobile":60,"padding_bottom_mobile":60,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"image_with_text_pR9RXR":{"type":"image-with-text","blocks":{"subheading_nNBqbG":{"type":"subheading","settings":{"subheading":"Stage 2: $22,499* Installed & Engineered"}},"heading_dHpa9y":{"type":"heading","settings":{"heading":"<strong>Stage 2: The Performance Level-Up<\/strong>","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2"}},"text_eiTTm6":{"type":"text","settings":{"text":"<p><em>Going all out with Fox 3.0 Race-Bred technology while retaining your factory wheel and tyre setup.<\/em><\/p><ul><li><strong>GVM Rating:<\/strong> 3,850kg (Boosting payload to <strong>1,028kg<\/strong>) <strong>GCM Rating:<\/strong> 8,350kg (Retains full 4.5T towing)<\/li><li><strong>Key Features:<\/strong> Fox 3.0 Internal Bypass Race Series Shocks (Front & Rear), ORI coil package, BDS Upper Control Arms & Diff Drop.<\/li><li><strong>Best For:<\/strong> 4WD tourers who tackle long-distance corrugations and demand elite damping without upgrading wheels or tyres.<\/li><li><strong>The Benefit:<\/strong> Stepping up to the 3.0 platform provides massive oil volume and internal bypass technology. You get a plush, \"cloud-like\" ride on the road that transforms into a bottomless, race-ready suspension when the terrain gets technical.<\/li><li><strong>Part Number: <\/strong>TUN-Stage2-GVM<\/li><\/ul>"}}},"block_order":["subheading_nNBqbG","heading_dHpa9y","text_eiTTm6"],"name":"t:sections.image-with-text.presets.name","settings":{"container":"container","color_schema":"","image":"shopify:\/\/shop_images\/GVM_TOYOTA-TUNDRA-20260504stage-2--3850GVM-_-8350-GCM.png","image_width":"50%","image_position":"right","vertical_alignment":"center","column_gap":"medium","row_gap":"medium","padding_left":0,"padding_right":0,"align_content_container":"none","mobile_padding_left":15,"mobile_padding_right":15,"padding_top":40,"padding_bottom":40,"padding_top_mobile":60,"padding_bottom_mobile":60,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"image_with_text_WzWKiJ":{"type":"image-with-text","blocks":{"subheading_6jjGGc":{"type":"subheading","settings":{"subheading":"Stage 3:  $20,999* Installed & Engineered"}},"heading_mEVqDg":{"type":"heading","settings":{"heading":"<strong>Stage 3: The Heavy Hauler<\/strong>","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2"}},"text_6RrFdR":{"type":"text","settings":{"text":"<p><em>Maximum legal capacity for the most demanding builds. Ideal for Tray & Canopy conversions.<\/em><\/p><ul><li><strong>GVM Rating:<\/strong> 4,300kg (Approx. <strong>1,478kg payload<\/strong>) <strong>GCM Rating:<\/strong> 8,800kg (The ultimate legal combination)<\/li><li><strong>Key Features:<\/strong> Fox 2.5 Performance Elite suspension, ORI 500kg heavy-duty coil packs.<\/li><li><strong>Best For:<\/strong> Fully built rigs with rear drawer systems, rooftop tents, long-range tanks, or heavy permanent canopies.<\/li><li><strong>The Benefit:<\/strong> A massive payload increase that transforms the Tundra into a true heavy-duty platform. This package solves the common \"overweight\" issue for fully kitted tourers while safely retaining its full 4.5T braked towing capacity.<\/li><li><strong>Wheels & Tyres Required:<\/strong> Specific wheels and tyres are required.<\/li><li><strong>Part Number: <\/strong>TUN-Stage3-GVM<\/li><\/ul>"}}},"block_order":["subheading_6jjGGc","heading_mEVqDg","text_6RrFdR"],"name":"t:sections.image-with-text.presets.name","settings":{"container":"container","color_schema":"","image":"shopify:\/\/shop_images\/GVM_TOYOTA-TUNDRA-20260504stage-3---4300GM-_-8800-GCM-copy.png","image_width":"50%","image_position":"left","vertical_alignment":"center","column_gap":"medium","row_gap":"medium","padding_left":0,"padding_right":0,"align_content_container":"none","mobile_padding_left":15,"mobile_padding_right":15,"padding_top":40,"padding_bottom":40,"padding_top_mobile":60,"padding_bottom_mobile":60,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"image_with_text_PCycim":{"type":"image-with-text","blocks":{"subheading_GcgNcf":{"type":"subheading","settings":{"subheading":"Stage 4: $27,999* Installed & Engineered"}},"heading_3XdiUk":{"type":"heading","settings":{"heading":"<strong>Stage 4: The \"No Compromise\" Build<\/strong>","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2"}},"text_Mbr9Gf":{"type":"text","settings":{"text":"<p><em>The absolute peak of Toyota Tundra performance and legality in Australia.<\/em><\/p><ul><li><strong>GVM Rating:<\/strong> 4,300kg (Approx. <strong>1,478kg payload<\/strong>)<\/li><li><strong>GCM Rating:<\/strong> 8,800kg<\/li><li><strong>Key Features:<\/strong> Fox 3.0 Internal Bypass Race Series Shocks (Front & Rear), ORI heavy-duty coil package and engineered for 35's<\/li><li><strong>Best For:<\/strong> The enthusiast who demands race-bred technology combined with maximum legal payload.<\/li><li><strong>The Benefit:<\/strong> The Fox 3.0 Bypass shocks offer unparalleled heat dissipation and damping control. This is the ultimate \"go-anywhere\" setup that remains 100% legally compliant across Australia, even when fully loaded and towing the boat or caravan.<\/li><li><strong>Part Number: <\/strong>TUN-Stage4-GVM<\/li><\/ul>"}}},"block_order":["subheading_GcgNcf","heading_3XdiUk","text_Mbr9Gf"],"name":"t:sections.image-with-text.presets.name","settings":{"container":"container","co