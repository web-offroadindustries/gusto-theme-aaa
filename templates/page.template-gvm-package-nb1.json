    "image_with_text_giCQLF": {
      "type": "image-with-text",
      "blocks": {
        "subheading_GUEKJN": {
          "type": "subheading",
          "settings": {
            "subheading": "Stage 6: $29,000* - Installed & Engineered"
          }
        },
        "heading_GqENUg": {
          "type": "heading",
          "settings": {
            "heading": "<strong>Stage 6: The Ultimate 6.5\" Goliath</strong>",
            "highlight_style": "none",
            "enable_highlight_text_color": false,
            "heading_size": "h2"
          }
        },
        "text_ddpBQL": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Best for:</strong> The uncompromising build. This is for the owner who wants the absolute maximum height, maximum tyre size, and zero compromises on ride quality. You get the towering 6.5-inch stance clearing 37s, the incredibly smooth coilover conversion, and 100% legal road compliance on a standard car licence.</p><ul><li><strong>Lift Height:</strong> 6.5 Inches</li><li><strong>Tyre Size:</strong> Engineered specifically for 37-inch tyres.</li><li><strong>Suspension Tech:</strong> Utilises a massive <strong>BDS 6.5\" Coilover Conversion Kit</strong>. This removes the stiff factory torsion bars completely, replacing them with a modern coil spring setup. It includes a full subframe drop, heavy-duty replacement knuckles, and upgraded upper and lower control arms to keep the geometry flawless at extreme heights.</li><li><strong>Shock Configuration:</strong> Massive <strong>Fox 2.5 Performance Elite Series Coilovers</strong> up front, paired with standard Fox 2.5 Elites in the rear. Both feature remote reservoirs and adjustable damping clickers, meaning a truck this huge actually rides smoother and absorbs hits better than it did rolling off the showroom floor.</li><li><strong>Extras:</strong> We also include colour-coded <strong>Husky Extenda Flares</strong> and <strong>ORI Metal mud flap brackets with rubber</strong> to ensure your vehicle is completely compliant and federally approved.</li><li><strong>What's Not Included:</strong> Just your wheels and tyres! All you need to do is pick your style. We have already set the specific wheel offsets required to keep the build federally compliant, so there is no need to stress about load ratings or legality.</li><li><strong>CHV-2500-STAGE-6-NB1</strong></li></ul>"
          }
        }
      },
      "block_order": [
        "subheading_GUEKJN",
        "heading_GqENUg",
        "text_ddpBQL"
      ],
