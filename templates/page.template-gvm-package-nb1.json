    "image_with_text_zgLfNt": {
      "type": "image-with-text",
      "blocks": {
        "subheading_KF8CC3": {
          "type": "subheading",
          "settings": {
            "subheading": "Stage 6 : $XX,XXX* - Installed & Engineered"
          }
        },
        "heading_eDyjtL": {
          "type": "heading",
          "settings": {
            "heading": "<strong>Stage 6: The \"MEGA \" Build (6.5-Inch BDS Coilover </strong>",
            "highlight_style": "none",
            "enable_highlight_text_color": false,
            "heading_size": "h2"
          }
        },
        "text_aW8UUa": {
          "type": "text",
          "settings": {
            "text": "<p><em>Ever wondered how these monsters get around legally? ORI Stage 6 makes the dream a reality.</em></p><ul><li><strong>GVM Rating:</strong> 6000kg | <strong>GCM:</strong> 12,474kg</li><li><strong>Key Features:</strong> Fox 2.5 Performance Elite with BDS Lift Kit Technology (6.5-Inch Coil-Over Suspension Lift engineered for up to 37\" Tyres), and ORI 500kg heavy-duty leaf packs. Engineered for up to 37” Tyres.</li><li><strong>Best For:</strong> The absolute hardcore enthusiast who demands a monster of a truck that still delivers heavy-duty NB2 payload limits and 4.5T towing capacity.</li><li><strong>Benefit:</strong> Fully engineered for ultimate comfort and control. Equipped with a 6.5” BDS Coil-Over lift kit, this setup is 100% legal Australia-wide exclusively via ORI's Pre-Rego packages under our SSM approval. Drive anywhere knowing your monster build is completely legal and safe.</li><li><strong>Part Number:</strong> VEH-STAGE6-GVM<br/></li></ul>"
          }
        }
      },
      "block_order": [
