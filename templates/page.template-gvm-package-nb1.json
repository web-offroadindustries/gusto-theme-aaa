    "image_with_text_M8ykcj": {
      "type": "image-with-text",
      "blocks": {
        "subheading_p3JeNT": {
          "type": "subheading",
          "settings": {
            "subheading": "Stage 3: $19,999* - Installed & Engineered"
          }
        },
        "heading_KMefdY": {
          "type": "heading",
          "settings": {
            "heading": "<strong>Stage 3: The Premium Comfort 3\" Coilover Conversion</strong>",
            "highlight_style": "none",
            "enable_highlight_text_color": false,
            "heading_size": "h2"
          }
        },
        "text_aVwiWh": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Best for:</strong> The owner who demands the absolute best ride quality possible. If you want to upgrade to a plush coilover front end but are concerned about engineering and compliance, this is your solution. The ORI Stage 3 package fully engineers the BDS Coilover conversion for your Chevy Silverado 2500HD, eliminating the harsh factory ride.</p><ul><li><strong>Lift Height:</strong> 3 Inches</li><li><strong>Tyre Size:</strong> Engineered for either 35-inch or 37-inch tyres.</li><li><strong>Suspension Tech:</strong> Utilises a comprehensive <strong>BDS 3\" Coilover Kit</strong> that features a complete <em>torsion bar delete</em>—the ultimate key to a smoother ride. This system includes premium front coilovers, heavy-duty tie rods, upgraded upper and lower control arms, and a rear block kit to dial in a perfectly level stance.</li><li><strong>Shock Configuration:</strong> Massive <strong>Fox 2.5 Performance Elite Series Shocks</strong> <em>(front coilovers and rear shocks)</em> featuring remote reservoirs and adjustable damping. You can literally dial in your comfort with a simple clicker—soften it up to float down the highway, or firm it up for off-road tracks and towing.</li><li><strong>Extras:</strong> We also include colour-coded <strong>Husky Extenda Flares</strong> and <strong>ORI Metal mud flap brackets with rubber</strong> to ensure your vehicle is completely compliant and federally approved.</li><li><strong>What's Not Included:</strong> Just your wheels and tyres! All you need to do is pick your style. We have already set the specific wheel offsets required to keep the build federally compliant, so there is no need to stress about load ratings or legality.</li><li><strong>CHV-2500-STAGE-3-NB1</strong></li></ul>"
          }
        }
      },
      "block_order": [
        "subheading_p3JeNT",
