    "image_with_text_9MGF8c": {
      "type": "image-with-text",
      "blocks": {
        "subheading_b3w7Fn": {
          "type": "subheading",
          "settings": {
            "subheading": "Stage 6.5 : $XX,XXX* - Installed & Engineered"
